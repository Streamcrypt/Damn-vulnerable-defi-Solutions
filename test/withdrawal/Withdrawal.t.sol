    vm.warp(START_TIMESTAMP + 7 days );

{
    bytes memory message = abi.encodeCall(L1Forwarder.forwardMessage, (0,0x328809Bc894f92807417D2dAD6b7C998c1aFdac6,0x9c52B2C4A89E2BE37972d18dA937cbAd8AA8bd50, hex"81191e51000000000000000000000000328809bc894f92807417d2dad6b7c998c1afdac60000000000000000000000000000000000000000000000008ac7230489e80000"));
    l1Gateway.finalizeWithdrawal(0, l2sender, target, timestamp, message, proof);
    bytes32 leaf = keccak256(abi.encode(0, l2sender, target, timestamp, message));
    console.logBytes32(leaf);
}

{
    timestamp = 1718786965 ;
    vm.warp(timestamp + 7 days );
    bytes memory message = abi.encodeCall(L1Forwarder.forwardMessage, (1,0x1D96F2f6BeF1202E4Ce1Ff6Dad0c2CB002861d3e,0x9c52B2C4A89E2BE37972d18dA937cbAd8AA8bd50, hex"81191e510000000000000000000000001d96f2f6bef1202e4ce1ff6dad0c2cb002861d3e0000000000000000000000000000000000000000000000008ac7230489e80000"));
